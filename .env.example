# Open Hémicycle — variables d'environnement (exemple)
# Copier en .env (NON commité) et remplir.

# --- PostgreSQL / Supabase ---
# Chaîne de connexion Postgres (Supabase: Project Settings > Database)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase (côté client / API)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="..."
# Clé service role : SERVEUR UNIQUEMENT, jamais exposée au client
SUPABASE_SERVICE_ROLE_KEY="..."

# --- ETL ---
# Législature courante
AN_LEGISLATURE="17"
# Dossier de stockage des dumps bruts (non commité)
DATA_RAW_DIR="./data/raw"
