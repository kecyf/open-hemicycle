# Open Hémicycle — variables d'environnement (exemple)
# Copier en .env (NON commité) et remplir.

# --- PostgreSQL / Supabase ---
# SEULE clé requise pour Drizzle (ETL + runtime) : la connexion Postgres porte
# déjà tous les droits et contourne la RLS. Supabase: Connect > ORM > Drizzle,
# Transaction pooler IPv4 (port 6543). Remplacer [YOUR-PASSWORD].
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres"

# Supabase — URL + clé publishable (sûres côté client)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Optionnel — uniquement si on utilise le SDK supabase-js (PostgREST) côté serveur.
# Inutile pour l'ETL Drizzle. Nouveau format = clé "sb_secret_..." (onglet API Keys).
# SUPABASE_SECRET_KEY="sb_secret_..."

# --- ETL ---
# Législature courante
AN_LEGISLATURE="17"
# Dossier de stockage des dumps bruts (non commité)
DATA_RAW_DIR="./data/raw"
